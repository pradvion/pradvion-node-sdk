{
  "name": "pradvion-node",
  "version": "0.1.2",
  "description": "Pradvion Node.js SDK — AI cost tracking, business signals, and client billing for agencies",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "pradvion-instrument": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/build-esm.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai", "llm", "openai", "anthropic",
    "cost-tracking", "billing", "agency",
    "pradvion", "observability"
  ],
  "author": "Pradip Vala <hello@pradvion.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradvion/pradvion-node-sdk"
  },
  "homepage": "https://pradvion.com",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "anthropic": ">=0.20.0",
    "@langchain/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true },
    "anthropic": { "optional": true },
    "@langchain/core": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
}
